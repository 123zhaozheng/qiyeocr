OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1

REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=recipient:extract:v1:
REDIS_TTL_SECONDS=86400

OPENAI_MODEL_TEXT=Qwen/Qwen3.5-35B-A3B
OPENAI_MODEL_IMAGE=Qwen/Qwen3.5-35B-A3B
OPENAI_TIMEOUT_SECONDS=60

FTP_HOST=127.0.0.1
FTP_PORT=21
FTP_USERNAME=demo
FTP_PASSWORD=demo
FTP_BASE_DIR=/upload/qiweiocr
FTP_TIMEOUT_SECONDS=30
FTP_PASSIVE=true
FTP_USE_TLS=false
FTP_ENCODING=utf-8
